{
  "name": "elevare-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Next.js content hub for the Elevare ecosystem.",
  "scripts": {
    "prebuild": "node ./scripts/generate-nutrition-data.mjs && node ./scripts/generate-training-data.mjs && node --experimental-strip-types ./scripts/generate-sitemaps.ts",
    "dev": "next dev",
    "build": "next build",
    "check:static": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test --experimental-strip-types ./tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "seo:audit": "node --experimental-strip-types ./scripts/seo-audit.ts"
  },
  "keywords": [
    "nextjs",
    "mdx",
    "blog",
    "fitness"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "gray-matter": "^4.0.3",
    "next": "^16.2.4",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "typescript": "^6.0.3"
  }
}
